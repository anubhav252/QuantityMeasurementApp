{
  "Jwt": {
    "Key": "my_super_secret_key_12345678901234567890_!@#",
    "Issuer": "QuantityAPI",
    "Audience": "QuantityAPIUsers"
  },
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/api/auth/{**catch-all}"
        }
      },
      "qma-route": {
        "ClusterId": "qma-cluster",
        "Match": {
          "Path": "/api/quantities/{**catch-all}"
        },
        "AuthorizationPolicy": "default"
      },
      "qma-public-route": {
        "ClusterId": "qma-cluster",
        "Match": {
          "Path": "/api/quantities/{operation}",
          "Methods": [ "POST" ]
        }
      },
      "history-route": {
        "ClusterId": "history-cluster",
        "Match": {
          "Path": "/api/history/{**catch-all}"
        },
        "AuthorizationPolicy": "default"
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "auth-service": {
            "Address": "http://localhost:5001"
          }
        }
      },
      "qma-cluster": {
        "Destinations": {
          "qma-service": {
            "Address": "http://localhost:5002"
          }
        }
      },
      "history-cluster": {
        "Destinations": {
          "history-service": {
            "Address": "http://localhost:5003"
          }
        }
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
